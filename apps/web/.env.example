# .env.example — Plantilla de variables de entorno
# Copia este archivo a .env.local y rellena los valores.
# .env.local está en .gitignore y NO se commitea.

# Firebase Web SDK config — obtener desde Firebase Console > Project Settings
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Conectar a emulators locales (Auth + Firestore) en lugar de Firebase real.
# Para desarrollo local contra emulator setear a "true".
# Para builds de producción (Vercel) dejar vacío o "false".
VITE_USE_EMULATORS=false
