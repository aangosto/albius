rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Placeholder: denegar todo por defecto.
    // Reglas reales pendientes de implementar al integrar Firebase Auth y custom claims.
    // Ver docs/02-modelo-de-datos.pdf §7 para el esquema completo.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
