rules_version = '2';

// ============================================================================
//  REGLAS DE SEGURIDAD FIRESTORE — Albius
// ============================================================================
//
//  Aislamiento multi-tenant estricto basado en custom claims del token JWT:
//    - rol:        'super_admin' | 'jefe_trafico' | 'conductor'
//    - tenantId:   id del tenant al que pertenece el usuario (no presente en
//                  super_admin, que tiene acceso global)
//    - centroId:   id del centro al que pertenece el usuario (no presente en
//                  super_admin)
//
//  Los custom claims se asignan vía Admin SDK desde Cloud Functions al crear
//  cada usuario. El cliente fuerza el refresco del token con
//  getIdTokenResult({ forceRefresh: true }) para que los claims nuevos
//  alcancen las reglas.
//
//  Esta sesión solo abre 4 colecciones (tenants, centros, usuarios,
//  conductores). El resto del modelo permanece con deny-all explícito hasta
//  que se aborde en su sesión correspondiente.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================================
    //  HELPERS
    // ========================================================================

    function isAuth() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuth() && request.auth.token.rol == 'super_admin';
    }

    function isJefeTrafico() {
      return isAuth() && request.auth.token.rol == 'jefe_trafico';
    }

    function isConductor() {
      return isAuth() && request.auth.token.rol == 'conductor';
    }

    // Comprueba que el documento pertenece al mismo tenant que el usuario.
    // El super_admin pasa por diseño porque su token NO lleva claim `tenantId`:
    // representa acceso global (uso interno para soporte y bootstrap).
    // IMPORTANTE: si en el futuro hay que restringir a super_admin sobre una
    // colección concreta, NO uses sameTenant() para esa regla — escribe una
    // condición específica que no incluya la rama isSuperAdmin().
    function sameTenant(tid) {
      return isSuperAdmin() || (isAuth() && request.auth.token.tenantId == tid);
    }

    // Mismo principio que sameTenant() respecto al super_admin.
    // Ver comentario sobre sameTenant() para la implicación de seguridad.
    function sameCentro(cid) {
      return isSuperAdmin() || (isAuth() && request.auth.token.centroId == cid);
    }

    function ownerOfDoc(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Devuelve true si la operación de update intenta modificar al menos uno
    // de los campos listados. Se usa para impedir que un usuario pueda alterar
    // campos sensibles de su propio documento (rol, tenantId, etc.).
    function fieldsChanged(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ========================================================================
    //  4.1  TENANTS
    // ========================================================================

    match /tenants/{tenantId} {
      allow read: if isSuperAdmin() || sameTenant(tenantId);
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin()
                    && !fieldsChanged([
                      'id',
                      'cif',
                      'fechaAlta',
                      'creadoPor',
                      'creadoEn'
                    ]);
      allow delete: if isSuperAdmin();
    }

    // ========================================================================
    //  4.2  CENTROS
    // ========================================================================

    match /centros/{centroId} {
      allow read: if isSuperAdmin()
                  || (isAuth() && sameTenant(resource.data.tenantId));
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin()
                    && !fieldsChanged([
                      'id',
                      'tenantId',
                      'fechaCreacion',
                      'creadoPor',
                      'creadoEn'
                    ]);
      allow delete: if isSuperAdmin();
    }

    // ========================================================================
    //  4.3  USUARIOS
    // ========================================================================
    //
    //  - create: prohibido desde cliente. Solo Cloud Functions (Admin SDK)
    //    pueden crear documentos /usuarios porque la operación requiere
    //    setear custom claims atómicamente en el mismo paso.
    //  - update super_admin: permitido salvo campos inmutables (id, creadoPor,
    //    creadoEn, fechaCreacion), vetados por defensa en profundidad (B13,
    //    cuestión 7) — simétrico a /tenants y /centros. El callable
    //    actualizarUsuario usa Admin SDK y bypassa estas reglas; el veto cubre
    //    el path de escritura directa de cliente.
    //  - update owner (self): puede tocar campos no sensibles (telefono,
    //    tokensFCM, ultimoLogin) pero NO los sensibles (rol, tenantId, centroId,
    //    conductorId, estado, passwordChangeRequired) ni los dual-homed
    //    (email, nombreCompleto). Estos dos últimos se añadieron en B13
    //    (cuestión 6 / D5.4): viven a la vez en el doc y en el Auth user record,
    //    así que su edición se canaliza obligatoriamente por callable con
    //    escritura dual (evita drift Auth↔doc). Ver TODO[perfil-self-edit-via-callable].
    //  - delete: solo super_admin. En la práctica se prefiere soft-delete
    //    mediante estado='suspendido'.
    //
    //  Bloque 7 (forzado de cambio de password) depende de la regla
    //  allow read sobre /usuarios/{uid} con ownerOfDoc(uid) que sigue
    //  más abajo. AuthContext hidrata el flag passwordChangeRequired
    //  leyendo el doc directamente desde el frontend. Si esta regla
    //  se restringe (p.ej. solo super_admin reads), el flujo de login
    //  se rompe: ProtectedRoute no puede gatear el flag. El endurecimiento
    //  de B13 NO toca la regla read self-only (sigue intacta más abajo).

    match /usuarios/{uid} {
      allow read: if isSuperAdmin()
                  || ownerOfDoc(uid)
                  || (isJefeTrafico() && sameTenant(resource.data.tenantId));

      allow create: if false;

      allow update: if (
                      isSuperAdmin()
                      && !fieldsChanged([
                        'id',
                        'creadoPor',
                        'creadoEn',
                        'fechaCreacion'
                      ])
                    )
                    || (
                      ownerOfDoc(uid)
                      && !fieldsChanged([
                        'rol',
                        'tenantId',
                        'centroId',
                        'conductorId',
                        'estado',
                        'passwordChangeRequired',
                        'email',
                        'nombreCompleto'
                      ])
                    );

      allow delete: if isSuperAdmin();
    }

    // ========================================================================
    //  4.4  CONDUCTORES
    // ========================================================================

    match /conductores/{conductorId} {
      allow read: if isSuperAdmin()
                  || (isAuth() && sameTenant(resource.data.tenantId));

      allow create: if (isSuperAdmin() || isJefeTrafico())
                    && sameTenant(request.resource.data.tenantId);

      allow update: if (isSuperAdmin() || isJefeTrafico())
                    && sameTenant(resource.data.tenantId);

      allow delete: if isSuperAdmin();
    }

    // ========================================================================
    //  4.5  LINEAS
    // ========================================================================
    //
    //  Línea OPERATIVA colgada de un centro (B16): el jefe de tráfico gestiona
    //  las líneas de su centro, no es una entidad de gobierno. Por eso el
    //  hermano correcto es /conductores (permite escritura de jefe scoped por
    //  tenant), no /centros (solo super_admin). Los callables crearLinea/
    //  actualizarLinea ya autorizan al jefe; la regla declara la misma política,
    //  no una más restrictiva que el backend contradiría.
    //
    //  `read` tenant-scoped: super_admin global + usuarios del tenant de la línea.
    //
    //  `write` (create/update): super_admin o jefe_trafico del mismo tenant
    //  (patrón /conductores), CON veto de inmutables (id, tenantId, centroId,
    //  creadoPor, creadoEn) en update por defensa en profundidad D6.x — esto
    //  último NO lo tiene /conductores, pero aquí lo queremos.
    //
    //  NOTA: la regla es tenant-scoped (sameTenant); el callable es
    //  centro-scoped (anti-cross-centro: un jefe solo toca líneas de SU centro).
    //  La verdad operativa la impone el callable (Admin SDK); la regla es la
    //  defensa de último recurso ante escritura directa de cliente. Mismo nivel
    //  de garantía que /conductores.

    match /lineas/{id} {
      allow read: if isSuperAdmin()
                  || (isAuth() && sameTenant(resource.data.tenantId));

      allow create: if (isSuperAdmin() || isJefeTrafico())
                    && sameTenant(request.resource.data.tenantId);

      allow update: if (isSuperAdmin() || isJefeTrafico())
                    && sameTenant(resource.data.tenantId)
                    && !fieldsChanged([
                      'id',
                      'tenantId',
                      'centroId',
                      'creadoPor',
                      'creadoEn'
                    ]);

      allow delete: if isSuperAdmin();
    }

    // ========================================================================
    //  4.6  TIPOS_TURNO
    // ========================================================================
    //
    //  Plantilla de tipo de turno OPERATIVA colgada de un centro (B18): el jefe
    //  de tráfico gestiona los tipos de su centro. Mismo patrón que /lineas
    //  (escritura de jefe scoped por tenant), NO /centros (solo super_admin).
    //  Los callables crear/actualizarTipoTurno autorizan al jefe; la regla
    //  declara la misma política, no una más restrictiva.
    //
    //  read tenant-scoped; write (create/update) super_admin o jefe del mismo
    //  tenant + veto de inmutables (id, tenantId, centroId, creadoPor, creadoEn)
    //  en update. La regla es tenant-scoped (sameTenant); el callable es
    //  centro-scoped (anti-cross-centro). La verdad operativa la impone el
    //  callable; la regla es defensa de último recurso. Listado de cliente: el
    //  jefe DEBE filtrar where('tenantId') por D6.5 (sameTenant en list no puede
    //  leer resource.data).

    match /tipos_turno/{id} {
      allow read: if isSuperAdmin()
                  || (isAuth() && sameTenant(resource.data.tenantId));

      allow create: if (isSuperAdmin() || isJefeTrafico())
                    && sameTenant(request.resource.data.tenantId);

      allow update: if (isSuperAdmin() || isJefeTrafico())
                    && sameTenant(resource.data.tenantId)
                    && !fieldsChanged([
                      'id',
                      'tenantId',
                      'centroId',
                      'creadoPor',
                      'creadoEn'
                    ]);

      allow delete: if isSuperAdmin();
    }

    // ========================================================================
    //  4.7  FRECUENCIAS  +  4.8  FRECUENCIAS_EXCEPCIONALES
    // ========================================================================
    //
    //  Datos DESCRIPTIVOS del servicio (intensidad de paso por línea/tramo),
    //  operativos del jefe (B23). Mismo patrón que /lineas y /tipos_turno
    //  (escritura de jefe scoped por tenant), NO /centros (super_admin-only).
    //  Cuelgan de una Línea (lineaId), por eso `lineaId` es inmutable junto a
    //  id/tenantId/centroId/creadoPor/creadoEn. read tenant-scoped (el list del
    //  jefe DEBE filtrar where('tenantId'), D6.5). La verdad operativa (línea
    //  activa, no-solape) la impone el callable; la regla es defensa de cliente.

    match /frecuencias/{id} {
      allow read: if isSuperAdmin()
                  || (isAuth() && sameTenant(resource.data.tenantId));

      allow create: if (isSuperAdmin() || isJefeTrafico())
                    && sameTenant(request.resource.data.tenantId);

      allow update: if (isSuperAdmin() || isJefeTrafico())
                    && sameTenant(resource.data.tenantId)
                    && !fieldsChanged([
                      'id',
                      'tenantId',
                      'centroId',
                      'lineaId',
                      'creadoPor',
                      'creadoEn'
                    ]);

      allow delete: if isSuperAdmin();
    }

    match /frecuencias_excepcionales/{id} {
      allow read: if isSuperAdmin()
                  || (isAuth() && sameTenant(resource.data.tenantId));

      allow create: if (isSuperAdmin() || isJefeTrafico())
                    && sameTenant(request.resource.data.tenantId);

      allow update: if (isSuperAdmin() || isJefeTrafico())
                    && sameTenant(resource.data.tenantId)
                    && !fieldsChanged([
                      'id',
                      'tenantId',
                      'centroId',
                      'lineaId',
                      'creadoPor',
                      'creadoEn'
                    ]);

      allow delete: if isSuperAdmin();
    }

    // ========================================================================
    //  4.20  CONVENIO
    // ========================================================================
    //
    //  Convenio SINGLETON por centro (B25): id = centroId, exactamente uno por
    //  centro. Parametriza las restricciones del optimizador. Mismo patrón que
    //  /lineas y /tipos_turno (escritura de jefe scoped por tenant), NO /centros
    //  (solo super_admin). El upsert real va por el callable guardarConvenio
    //  (Admin SDK); la regla declara la misma política + veto de inmutables (id,
    //  tenantId, centroId, creadoPor, creadoEn) en update por defensa en
    //  profundidad.
    //
    //  read es get-by-id (id = centroId, NO list) → el bug D6.5 de sameTenant en
    //  list (no puede leer resource.data) NO aplica aquí: en un get, resource.data
    //  está disponible y sameTenant(resource.data.tenantId) evalúa correctamente.

    match /convenio/{centroId} {
      allow read: if isSuperAdmin()
                  || (isAuth() && sameTenant(resource.data.tenantId));

      allow create: if (isSuperAdmin() || isJefeTrafico())
                    && sameTenant(request.resource.data.tenantId);

      allow update: if (isSuperAdmin() || isJefeTrafico())
                    && sameTenant(resource.data.tenantId)
                    && !fieldsChanged([
                      'id',
                      'tenantId',
                      'centroId',
                      'creadoPor',
                      'creadoEn'
                    ]);

      allow delete: if isSuperAdmin();
    }

    // ========================================================================
    //  COLECCIONES NO ABIERTAS EN ESTA SESIÓN — DENY-ALL EXPLÍCITO
    // ========================================================================
    //
    //  Cada colección del modelo que no hemos abierto en la sesión actual se
    //  cierra explícitamente. Cuando se aborde la sesión correspondiente,
    //  sustituir el deny-all por las reglas específicas de esa colección.
    //
    //  NO añadir un wildcard `match /{path=**}` final: queremos que la
    //  presencia o ausencia de una entrada por colección sea explícita.

    match /paradas/{id}                   { allow read, write: if false; }
    match /servicios/{id}                 { allow read, write: if false; }
    match /cuadrantes/{id}                { allow read, write: if false; }
    match /versiones_cuadrante/{id}       { allow read, write: if false; }
    match /asignaciones/{id}              { allow read, write: if false; }
    match /cambios_asignaciones/{id}      { allow read, write: if false; }
    match /preferencias_permanentes/{id}  { allow read, write: if false; }
    match /preferencias_puntuales/{id}    { allow read, write: if false; }
    match /solicitudes_intercambio/{id}   { allow read, write: if false; }
    match /incidencias/{id}               { allow read, write: if false; }
    match /festivos/{id}                  { allow read, write: if false; }
    match /notificaciones/{id}            { allow read, write: if false; }
    match /audit_logs/{id}                { allow read, write: if false; }
  }
}
